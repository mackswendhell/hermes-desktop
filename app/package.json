{
  "name": "hermes-assistente",
  "version": "0.1.0",
  "description": "Assistente de mesa do Hermes — personagem flutuante com conversa por voz",
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "npm run build && electron .",
    "dist": "npm run build && node scripts/make-ico.mjs && electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.macks.hermes-assistente",
    "productName": "Hermes Assistente",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "shortcutName": "Hermes Assistente"
    }
  }
}
