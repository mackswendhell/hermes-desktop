{
  "name": "hermes-assistente",
  "version": "0.2.0",
  "description": "Assistente de mesa do Hermes — personagem flutuante com conversa por voz",
  "author": "Macks Wendhell",
  "main": "dist/main.js",
  "private": true,
  "repository": "github:mackswendhell/hermes-desktop",
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "npm run build && electron .",
    "dist": "npm run dist:win",
    "dist:win": "npm run build && node scripts/make-ico.mjs && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.macks.hermes-assistente",
    "productName": "Hermes Assistente",
    "afterPack": "scripts/mac-adhoc-sign.mjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "assets/icon-mac.png",
      "category": "public.app-category.utilities",
      "identity": null,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "O Hermes usa o microfone para conversar por voz."
      }
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "shortcutName": "Hermes Assistente"
    }
  },
  "dependencies": {
    "msedge-tts": "^2.0.7"
  }
}
